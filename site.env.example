# Per-deployment machine-specific shell env for the campaign scripts.
# Copy to site.env (gitignored) and fill in your paths. Keeps cluster-specific
# paths OUT of tracked code (the "no /n/ in code" CI gate, docs §10).
#
# The python image/site layer uses site.yaml (see site.example.yaml); this file
# is its shell analog, sourced by scripts/sbatch_champsim_ablation.sh.
#
# All optional. If unset:
#   ARCHBENCH_GEMMA4_ENDPOINT_JSON  -> empty (REQUIRED for Gemma-4 runs; set it here)
#   ARCHBENCH_EXP_SCRATCH           -> $ARCHBENCH_SCRATCH_DIR, else <repo>/results/archbench_campaign

# export ARCHBENCH_GEMMA4_ENDPOINT_JSON=/path/to/your/vllm/gemma4_endpoint.json
# export ARCHBENCH_EXP_SCRATCH=/your/large/scratch/archbench_campaign

# Judge backend for llm_judge evaluators (advisory; self-eval bias when = agent model):
#   export ARCHBENCH_JUDGE_MODEL=gemma4
#   (or export ANTHROPIC_API_KEY=... where the node has internet)
